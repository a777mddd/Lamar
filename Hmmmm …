<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>لعبة الأسئلة 💗</title>
<style>
body {
    margin: 0;
    font-family: Arial;
    background: linear-gradient(135deg, #ffc0cb, #ff69b4);
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.card {
    background: #fff;
    padding: 30px;
    border-radius: 20px;
    text-align: center;
    width: 300px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.question {
    font-size: 20px;
    margin-bottom: 20px;
}

.btn {
    background: #ff4da6;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 12px;
    margin: 5px;
    cursor: pointer;
    font-size: 16px;
    transition: 0.3s;
}

.btn:hover {
    background: #ff1a8c;
}
</style>
</head>
<body>

<div class="card">
    <div id="question" class="question"></div>
    <div id="answers"></div>
</div>

<script>
let step = 1;

function render() {
    const q = document.getElementById("question");
    const a = document.getElementById("answers");

    a.innerHTML = "";

    if (step === 1) {
        q.innerText = "انتي لمار ؟";
        button("اي", () => step = 2);
        button("لا", () => step = 1);
    }

    else if (step === 2) {
        q.innerText = "هلا والله ابوي انا هلا بالقطوه لمار 😋";
        button("هلا والله", () => step = 3);
    }

    else if (step === 3) {
        q.innerText = "عندي لك شي !!";
        button("هلا قول", () => step = 4);
    }

    else if (step === 4) {
        q.innerText = "تحبين أحمد ؟ 🤨";
        button("ما ادري ليش ؟", () => step = 5);
    }

    else if (step === 5) {
        q.innerText = "جاوبي بصراحه ولا اعض 😡😡";
        button("اي", () => step = 6);
        button("لا", () => step = 7);
    }

    else if (step === 7) {
        q.innerText = "انقلعي برا الموقع يا قليلة الادب 😒";
        button("خلاص خلاص اسفه نبدي من جديد", () => step = 1);
    }

    else if (step === 6) {
        q.innerText = "ادري الموضوع صار بسرعه ولا توقعت انني راح احبج بهالسرعه لاكن اتوقع انج تدرين من قبل انه اول ما عرفتج ما ادري شلون لاكن حبيتج وهذا شي ما اسويه العاده لاكن كانت كسر للعاده المهم انني احبج 😘";
    }
}

function button(text, action) {
    const btn = document.createElement("button");
    btn.className = "btn";
    btn.innerText = text;
    btn.onclick = () => {
        action();
        render();
    };
    document.getElementById("answers").appendChild(btn);
}

render();
</script>

</body>
</html>
